# Copy to .env.local and fill in.
# Only NEXT_PUBLIC_-prefixed vars reach the browser bundle.

# Upstream API base — SERVER-ONLY (no NEXT_PUBLIC_). The browser never calls it
# directly; all access is proxied through the Next.js server.
API_BASE_URL=https://dummyjson.com

# Access-token lifetime (minutes) requested at login/refresh. Lower it (e.g. 1)
# to exercise the refresh flow during a demo.
ACCESS_TOKEN_TTL_MINUTES=30

# Refresh proactively when the access token has fewer than this many seconds left.
REFRESH_SKEW_SECONDS=30

# Override for the Secure cookie flag (true/false). Defaults to secure in
# production. Set to `false` on plain-HTTP deployments (e.g. a box reached by IP)
# — the browser won't send Secure cookies over http, which would break auth.
# COOKIE_SECURE=false

# The app's own origin (default base for the public `apiFetch`). NOT the upstream.
NEXT_PUBLIC_API_URL=http://localhost:3000
